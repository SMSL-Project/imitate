<?xml version="1.0"?>
<robot name="land_with_downslope">
  <!-- Materials -->
  <material name="brown">
    <color rgba="0.61176471 0.45882353 0.37254902 1"/>
  </material>
  <material name="red">
    <color rgba="0.7 0.0 0.0 1"/>
  </material>

  <!-- Base Link -->
  <link name="baseLink">
    <contact>
      <lateral_friction value="0.3"/>
      <rolling_friction value="0.0001"/>
      <inertia_scaling value="3.0"/>
    </contact>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1"/>
    </inertial>

    <!-- Main body: a single box with the same overall dimensions.
         The original two horizontal red plates were at z=0.001 and z=0.018
         with thickness 0.002. Thus the overall height is 0.019 and the
         center of that box (for visual/collision) is at z = 0.0095. -->
    <visual>
      <origin xyz="0 0 0.0095"/>
      <geometry>
        <box size="0.15 0.22 0.019"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0095"/>
      <geometry>
        <box size="0.15 0.22 0.019"/>
      </geometry>
    </collision>

    <!-- Slope -->
    <visual>
      <origin xyz="-0.091454 0.055 0.0095" rpy="0 -0.5236 0"/>
      <geometry>
        <box size="0.038 0.11 0.002"/>
      </geometry>
      <material name="brown"/>
    </visual>
    <collision>
      <origin xyz="-0.091454 0.055 0.0095" rpy="0 -0.5236 0"/>
      <geometry>
        <box size="0.038 0.11 0.002"/>
      </geometry>
    </collision>
  </link>

  <!-- Slot links -->
  <link name="wolf_slot">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>
  <link name="sheep_slot">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>
  <link name="steve_slot">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>
  <link name="grass_slot">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <!-- Slot joints -->
  <joint name="wolf_slot_joint" type="fixed">
    <parent link="baseLink"/>
    <child link="wolf_slot"/>
    <origin xyz="0.02 -0.02 0.02"/>
  </joint>
  <joint name="sheep_slot_joint" type="fixed">
    <parent link="baseLink"/>
    <child link="sheep_slot"/>
    <origin xyz="-0.02 0.02 0.02"/>
  </joint>
  <joint name="steve_slot_joint" type="fixed">
    <parent link="baseLink"/>
    <child link="steve_slot"/>
    <origin xyz="-0.02 -0.02 0.02"/>
  </joint>
  <joint name="grass_slot_joint" type="fixed">
    <parent link="baseLink"/>
    <child link="grass_slot"/>
    <origin xyz="0.02 0.02 0.02"/>
  </joint>
</robot>

